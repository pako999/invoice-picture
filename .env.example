# Neon PostgreSQL — https://neon.tech
# Kopiraj "Connection string" iz Neon dashboarda (pooled connection)
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address (mora biti verificiran v Resend)
RESEND_FROM=racuni@tvoje-podjetje.si

# JWT secret — generiraj z: openssl rand -hex 32
JWT_SECRET=spremenite-v-naklucnih-64-znakov-za-produkcijo
